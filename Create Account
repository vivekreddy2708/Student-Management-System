package student_mangement;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;
import java.sql.Statement;
import java.util.Scanner;

public class Create_Account {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner sc=new Scanner(System.in);
		while(true) {
			System.out.println("1.Create DataBase\n2.Go back");
			int a=sc.nextInt();
			switch(a) {
			case 1:try {
				Class.forName("com.mysql.cj.jdbc.Driver");
				Connection con=DriverManager.getConnection("jdbc:mysql://localhost:3306/student_management?user=root&&password=12345678");
				//Statement st=con.createStatement();
				//st.execute("create table student(id int primary key,name varchar(30),address varchar(50),mobile long,email varchar(40) unique,password varchar(20) not null)");
				PreparedStatement ps=con.prepareStatement("insert into student values(?,?,?,?,?,?)");
				System.out.println("enter id");
				int id=sc.nextInt();
				ps.setInt(1,id);
				System.out.println("enter name");
				String name=sc.next();
				ps.setString(2, name);
				System.out.println("enter address");
				String add=sc.next();
				ps.setString(3, add);
				System.out.println("enter mobile");
				long mobile=sc.nextLong();
				ps.setLong(4, mobile);
				System.out.println("enter email");
				String email=sc.next();
				ps.setString(5, email);
				System.out.println("enter password");
				String pass=sc.next();
				ps.setString(6,pass);
				ps.executeUpdate();
			}
			catch(ClassNotFoundException | SQLException e) {
				e.printStackTrace();
			}break;
			default:System.out.println("enter valid input");
			}
			
		}

	}

	

}
